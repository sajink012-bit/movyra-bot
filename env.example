# ============================================================
#  MovYra Bot — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit the real .env file to Git!
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Your Telegram user ID (get it from @userinfobot)
# Multiple admins: comma-separated  e.g. 123456,789012
ADMIN_IDS=your_telegram_user_id_here

# ── OPTIONAL — GROUP ─────────────────────────────────────────
# Telegram group ID for your main MovYra community
# (a negative number like -1001234567890)
MAIN_GROUP_ID=

# Public invite link for the main group
MAIN_GROUP_LINK=https://t.me/movyra

# ── OPTIONAL — WEBSITE ───────────────────────────────────────
WEBSITE_URL=https://movyra.com
WEBSITE_API_URL=https://movyra.com/api

# ── OPTIONAL — DATABASE ──────────────────────────────────────
DB_PATH=movyra.db

# ── OPTIONAL — LOGGING ───────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
